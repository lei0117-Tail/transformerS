<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" version="29.6.6">
  <diagram name="Encoder Layer Detail" id="encoder-detail">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;Encoder Layer 内部数据流（Pre-LN 模式）&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="420" y="10" width="440" height="36" as="geometry" />
        </mxCell>

        <!-- Input -->
        <mxCell id="input_label" value="&lt;b&gt;输入 x&lt;/b&gt; (Embedding 输出)&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;[I, love, you]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;shape: [batch=1, seq_len=3, d_model=512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- ==================== SUB-LAYER 1: MHA ==================== -->
        <mxCell id="sl1_container" value="&lt;b&gt;子层一：Multi-Head Self-Attention&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;双向注意力：每个 token 可以看所有 token&lt;/font&gt;" style="swimlane;startSize=34;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="700" height="260" as="geometry" />
        </mxCell>

        <!-- MHA detail breakdown -->
        <mxCell id="s1_residual" value="residual = x&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;保存原始向量&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=10;" vertex="1" parent="sl1_container">
          <mxGeometry x="15" y="50" width="130" height="46" as="geometry" />
        </mxCell>
        <mxCell id="s1_norm" value="&lt;b&gt;LayerNorm&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot; font-size=&quot;9&quot;&gt;归一化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="sl1_container">
          <mxGeometry x="175" y="50" width="100" height="46" as="geometry" />
        </mxCell>

        <!-- QKV projection -->
        <mxCell id="s1_qkv_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=1;dashed=1;" vertex="1" parent="sl1_container">
          <mxGeometry x="310" y="42" width="360" height="62" as="geometry" />
        </mxCell>
        <mxCell id="s1_qkv_title" value="&lt;b&gt;Q, K, V 投影（都来自 x 本身）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#9673a6;fontSize=9;" vertex="1" parent="sl1_container">
          <mxGeometry x="385" y="44" width="210" height="18" as="geometry" />
        </mxCell>
        <mxCell id="s1_q" value="Q = x·W_Q&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1,3,512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=9;" vertex="1" parent="sl1_container">
          <mxGeometry x="320" y="62" width="100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="s1_k" value="K = x·W_K&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1,3,512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=9;" vertex="1" parent="sl1_container">
          <mxGeometry x="430" y="62" width="100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="s1_v" value="V = x·W_V&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1,3,512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=9;" vertex="1" parent="sl1_container">
          <mxGeometry x="545" y="62" width="105" height="34" as="geometry" />
        </mxCell>

        <!-- Scaled Dot Product Attention -->
        <mxCell id="s1_sdpa" value="&lt;b&gt;Scaled Dot-Product Attn&lt;/b&gt;&amp;#xa;Q·Kᵀ / √dₖ → Softmax → ·V&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1, heads, 3, 64] → [1, 3, 512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=10;arcSize=12;strokeWidth=2;" vertex="1" parent="sl1_container">
          <mxGeometry x="355" y="125" width="230" height="56" as="geometry" />
        </mxCell>

        <!-- W_O projection -->
        <mxCell id="s1_wo" value="W_O 投影&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;合头 → [1, 3, 512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=10;" vertex="1" parent="sl1_container">
          <mxGeometry x="620" y="132" width="65" height="44" as="geometry" />
        </mxCell>

        <mxCell id="s1_dropout" value="Dropout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#666666;fontSize=9;" vertex="1" parent="sl1_container">
          <mxGeometry x="425" y="198" width="80" height="36" as="geometry" />
        </mxCell>
        <mxCell id="s1_add" value="&lt;b&gt;Add&lt;/b&gt;&lt;br&gt;x + output&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;残差连接①&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="sl1_container">
          <mxGeometry x="365" y="210" width="110" height="42" as="geometry" />
        </mxCell>
        <mxCell id="s1_result" value="&lt;b&gt;中间输出 x₁&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot; font-size=&quot;9&quot;&gt;融合了所有 token 的上下文信息&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1, 3, 512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=10;" vertex="1" parent="sl1_container">
          <mxGeometry x="240" y="215" width="250" height="36" as="geometry" />
        </mxCell>

        <!-- Sublayer 1 internal arrows -->
        <mxCell id="sa1_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.2;" edge="1" parent="sl1_container" source="s1_norm" target="s1_qkv_box">
          <mxGeometry relative="1" as="geometry" />
