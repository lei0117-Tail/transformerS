        <!-- ==================== SUB-LAYER 2: FFN ==================== -->
        <mxCell id="sl2_container" value="&lt;b&gt;子层二：Feed Forward Network (FFN)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;逐位置独立处理（Position-wise），token 之间不交互&lt;/font&gt;" style="swimlane;startSize=34;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="30" y="450" width="720" height="280" as="geometry" />
        </mxCell>

        <mxCell id="s2_residual" value="residual = x₁&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;保存中间结果&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="15" y="50" width="130" height="46" as="geometry" />
        </mxCell>
        <mxCell id="s2_norm" value="&lt;b&gt;LayerNorm&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot; font-size=&quot;9&quot;&gt;归一化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="175" y="50" width="100" height="46" as="geometry" />
        </mxCell>
        <mxCell id="s2_linear1" value="&lt;b&gt;Linear₁&lt;/b&gt;&lt;br&gt;512 → 2048&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;升维 4× (W₁, b₁)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="310" y="44" width="115" height="54" as="geometry" />
        </mxCell>
        <mxCell id="s2_act" value="&lt;b&gt;ReLU / GELU&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;非线性激活 + 特征选择&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="455" y="44" width="125" height="54" as="geometry" />
        </mxCell>
        <mxCell id="s2_linear2" value="&lt;b&gt;Linear₂&lt;/b&gt;&lt;br&gt;2048 → 512&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;降回原维度 (W₂, b₂)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="380" y="118" width="115" height="54" as="geometry" />
        </mxCell>
        <mxCell id="s2_dropout" value="Dropout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#666666;fontSize=9;" vertex="1" parent="sl2_container">
          <mxGeometry x="530" y="128" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s2_add" value="&lt;b&gt;Add&lt;/b&gt;&lt;br&gt;x + output&amp;#xa;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;残差连接②&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="350" y="195" width="110" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_final" value="&lt;b&gt;最终输出 x₂&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot; font-size=&quot;9&quot;&gt;上下文信息 + FFN 非线性加工&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;8&quot;&gt;[1, 3, 512] → 送入下一层 Encoder Layer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=10;" vertex="1" parent="sl2_container">
          <mxGeometry x="200" y="218" width="340" height="48" as="geometry" />
        </mxCell>

        <!-- Sublayer 2 arrows -->
        <mxCell id="sa2_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.2;" edge="1" parent="sl2_container" source="s2_norm" target="s2_linear1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=1.2;" edge="1" parent="sl2_container" source="s2_linear1" target="s2_act">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=1.2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="sl2_container" source="s2_act" target="s2_linear2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.2;" edge="1" parent="sl2_container" source="s2_linear2" target="s2_dropout">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#b85450;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="sl2_container" source="s2_dropout" target="s2_add">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_6" value="residual" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="sl2_container" source="s2_residual" target="s2_add">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa2_7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="sl2_container" source="s2_add" target="s2_final">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow s1 to s2 -->
        <mxCell id="s1_to_s2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="sl1_container" target="sl2_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== KEY DIFFERENCE NOTE ==================== -->
        <mxCell id="diff_note" value="&lt;b&gt;🔑 Encoder vs Decoder 的关键区别&lt;/b&gt;" style="swimlane;startSize=28;fillColor=#fafafa;strokeColor=#999999;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="420" height="300" as="geometry" />
        </mxCell>

        <mxCell id="diff_enc" value="&lt;b&gt;Encoder Layer&lt;/b&gt;&lt;br&gt;• Self-Attention: &lt;b&gt;双向&lt;/b&gt;（无 Causal Mask）&lt;br&gt;• 每个位置可以看所有其他位置&lt;br&gt;• 只有 &lt;b&gt;2 个子层&lt;/b&gt;: MHA + FFN&lt;br&gt;• Q = K = V = x（自己查自己）&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#6c8ebf&quot;&gt;类比：开卷考试，可以看整篇文章&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#6c8ebf;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="diff_note">
          <mxGeometry x="15" y="40" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="diff_dec" value="&lt;b&gt;Decoder Layer&lt;/b&gt;&lt;br&gt;• Self-Attention: &lt;b&gt;单向&lt;/b&gt;（有 Causal Mask）&lt;br&gt;• 每个位置只能看自己和之前的位置&lt;br&gt;• 有 &lt;b&gt;3 个子层&lt;/b&gt;: + Cross-Attn&lt;br&gt;• Cross-Attn: Q=Dec, K/V=Enc&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#9673a6&quot;&gt;类比：闭卷写作，写完一句才能写下一句&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fd;strokeColor=#9673a6;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="diff_note">
          <mxGeometry x="15" y="175" width="380" height="112" as="geometry" />
        </mxCell>

        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend" value="&lt;b&gt;图例&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#fafafa;strokeColor=#cccccc;fontColor=#333333;horizontal=1;container=1;collapsible=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="490" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="leg_norm" value="LayerNorm（归一化）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="15" y="38" width="155" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg_attn" value="Attention（注意力）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="15" y="76" width="155" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg_ffn" value="FFN 线性变换" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="15" y="114" width="155" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg_add" value="Add（残差连接）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="30" y="152" width="110" height="32" as="geometry" />
        </mxCell>
        <mxCell id="leg_io" value="输入 / 输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="15" y="178" width="120" height="28" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

