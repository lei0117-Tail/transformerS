          <mxGeometry x="40" y="410" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="wave3_label" value="&lt;b&gt;i=127 (dim 509,510)&lt;/b&gt;&#xa;ω = 1/10000^(254/512) ≈ &lt;b&gt;99.98&lt;/b&gt;&#xa;&lt;font color=&quot;#999999&quot;&gt;高频: 快速振荡&#xa;捕获精确位置信息&lt;/font&gt;" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
