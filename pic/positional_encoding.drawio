        <mxCell id="wave0_label" value="&lt;b&gt;i=0 (dim 0,1)&lt;/b&gt;&#xa;ω = 1/10000^0 = &lt;b&gt;1&lt;/b&gt;&#xa;&lt;font color=&quot;#999999&quot;&gt;低频: 慢速变化&#xa;捕获长距离位置信息&lt;/font&gt;" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
