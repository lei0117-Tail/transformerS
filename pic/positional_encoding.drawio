<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" version="29.6.6">
  <diagram name="Positional Encoding" id="pos-enc">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Sinusoidal Positional Encoding 原理&lt;/b&gt;" style="text;html=1;fontSize=22;fontColor=#333333;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== Section 1: Formula ==================== -->
        <mxCell id="formula_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="520" height="130" as="geometry" />
        </mxCell>

        <mxCell id="formula_title" value="&lt;b&gt;核心公式&lt;/b&gt;" style="text;html=1;fontSize=14;fontColor=#333333;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="formula_pe" value="PE(pos, 2i)   = sin(pos / 10000^(2i/d_model))" style="text;html=1;fontSize=13;fontColor=#b85450;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="118" width="480" height="28" as="geometry" />
        </mxCell>

        <mxCell id="formula_po" value="PE(pos, 2i+1) = cos(pos / 10000^(2i/d_model))" style="text;html=1;fontSize=13;fontColor=#82b366;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="480" height="28" as="geometry" />
        </mxCell>

        <mxCell id="formula_note" value="其中: pos=位置索引, i=维度索引, d_model=模型维度 (通常512)" style="text;html=1;fontSize=11;fontColor=#666666;fontStyle=3;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="178" width="480" height="22" as="geometry" />
        </mxCell>

        <!-- ==================== Section 2: Dimension Table ==================== -->
        <mxCell id="dim_table" value="" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="590" y="80" width="310" height="130" as="geometry" />
        </mxCell>
        <mxCell id="dim_header" value="&lt;b&gt;维度分配规则&lt;/b&gt;" style="text;html=1;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;swimlaneHead=0;swimlaneBody=0;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="dim_table">
          <mxGeometry x="0" y="0" width="310" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dim_row1" value="&lt;b&gt;偶数维度 (0,2,4,...)&lt;/b&gt;  →  sin()" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;fillColor=#fff2cc;strokeColor=#d6b656;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;" vertex="1" parent="dim_table">
          <mxGeometry x="0" y="30" width="310" height="32" as="geometry" />
        </mxCell>
        <mxCell id="dim_row2" value="&lt;b&gt;奇数维度 (1,3,5,...)&lt;/b&gt;  →  cos()" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;fillColor=#d5e8d4;strokeColor=#82b366;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;" vertex="1" parent="dim_table">
          <mxGeometry x="0" y="62" width="310" height="32" as="geometry" />
        </mxCell>
        <mxCell id="dim_row3" value="同一对 (sin, cos) 共享相同的频率 ω = 1/10000^(2i/d_model)" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;fillColor=#f5f5f5;strokeColor=#666666;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontStyle=3;" vertex="1" parent="dim_table">
          <mxGeometry x="0" y="94" width="310" height="36" as="geometry" />
        </mxCell>

        <!-- ==================== Section 3: Frequency Visualization ==================== -->
        <mxCell id="freq_title" value="&lt;b&gt;不同维度的频率变化&lt;/b&gt;&#xa;(d_model=512, 展示前4对维度)" style="text;html=1;fontSize=14;fontColor=#333333;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="150" y="230" width="400" height="35" as="geometry" />
        </mxCell>

        <!-- Low frequency wave (i=0) -->
