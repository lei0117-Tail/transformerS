        <!-- Frequency spectrum note -->
        <mxCell id="freq_spectrum" value="&lt;b&gt;频率谱&lt;/b&gt;&#xa;从低频到高频呈 &lt;b&gt;几何级数&lt;/b&gt; 分布&#xa;覆盖从「全局位置」到「局部细节」的全部尺度" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="410" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Key insight box -->
        <mxCell id="key_insight" value="&lt;b&gt;🔑 核心设计思想&lt;/b&gt;&#xa;&#xa;每个位置得到一个 &lt;b&gt;唯一的&lt;/b&gt; 编码向量：&#xa;• 低频分量 → 区分「第1个词」vs「第100个词」&#xa;• 高频分量 → 区分「第101个词」vs「第102个词」&#xa;• sin/cos 配对 → 模型可以学习到 &lt;b&gt;相对位置&lt;/b&gt; (PE(pos+k) 可由 PE(pos) 线性表示)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="410" width="260" height="120" as="geometry" />
        </mxCell>

