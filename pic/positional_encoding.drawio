        <!-- ==================== Section 5: Why Sinusoidal? ==================== -->
        <mxCell id="why_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="780" width="720" height="95" as="geometry" />
        </mxCell>
        <mxCell id="why_title" value="&lt;b&gt;为什么选择 Sinusoidal（正弦）函数？&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#333333;fontStyle=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="783" width="350" height="25" as="geometry" />
        </mxCell>
        <mxCell id="why_1" value="&lt;b&gt;① 无需学习参数&lt;/b&gt; — 固定公式计算，节省内存，且可推广到训练时未见过的序列长度" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="810" width="340" height="22" as="geometry" />
        </mxCell>
        <mxCell id="why_2" value="&lt;b&gt;② 相对位置可表示&lt;/b&gt; — PE(pos+k) 是 PE(pos) 的线性函数，模型自然学到相对位置关系" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="832" width="360" height="22" as="geometry" />
        </mxCell>
        <mxCell id="why_3" value="&lt;b&gt;③ 唯一性&lt;/b&gt; — 每个位置对应唯一的编码向量，不会出现两个位置编码相同的情况" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="430" y="810" width="330" height="22" as="geometry" />
        </mxCell>
        <mxCell id="why_4" value="&lt;b&gt;④ 数值范围有界&lt;/b&gt; — sin/cos 值域 [-1,1]，与 Token Embedding 叠加后数值稳定" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="430" y="832" width="330" height="22" as="geometry" />
        </mxCell>

        <!-- Alternative: Learnable PE note -->
        <mxCell id="alt_note" value="&lt;b&gt;变体: Learnable PE（可学习位置编码）&lt;/b&gt; — BERT/GPT 使用 nn.Embedding(seq_len, d_model) 直接学习每个位置的向量，&#xa;优点: 更灵活；缺点: 无法泛化到超过训练最大长度，参数量随 seq_len 线性增长" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="150" y="890" width="520" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

