        </mxCell>
        <mxCell id="wave1_label" value="&lt;b&gt;i=1 (dim 2,3)&lt;/b&gt;&#xa;ω = 1/10000^(2/512) ≈ &lt;b&gt;0.11&lt;/b&gt;&#xa;&lt;font color=&quot;#999999&quot;&gt;中低频: 中等变化速度&lt;/font&gt;" style="text;html=1;fontSize=11;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
