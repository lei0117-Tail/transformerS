        <!-- Key insights -->
        <mxCell id="insights_box" value="&lt;b&gt;💡 关键洞察&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#fff8e1;strokeColor=#ffa000;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;fontSize=11;" vertex="1" parent="full_container">
          <mxGeometry x="20" y="330" width="950" height="155" as="geometry" />
        </mxCell>

        <mxCell id="insight1" value="&lt;b&gt;1. 参数量 ∝ d_model²&lt;/b&gt;&lt;br&gt;每个线性层的参数都是 d_in × d_out，所以 d_model 翻倍 → 参数翻 4 倍！&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;这就是为什么 GPT-3 (d=12288) 有 1750 亿参数&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffa000;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="insights_box">
          <mxGeometry x="15" y="36" width="450" height="54" as="geometry" />
        </mxCell>
        <mxCell id="insight2" value="&lt;b&gt;2. FFN 是参数大头（~67%/层）&lt;/b&gt;&lt;br&gt;因为 d_ff = 4 × d_model，两个大矩阵 W₁(4d²) + W₂(4d²) = 8d²&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;而 Attention 只有 4 个 d² 矩阵 (W_Q,W_K,W_V,W_O)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffa000;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="insights_box">
          <mxGeometry x="480" y="36" width="450" height="54" as="geometry" />
        </mxCell>
        <mxCell id="insight3" value="&lt;b&gt;3. Decoder 比 Encoder 参数更多&lt;/b&gt;&lt;br&gt;Decoder 多了一整套 Cross-Attention 参数（额外的 W_Q,W_K,W_V,W_O）&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;每层多 ~d_model² × 4 个参数&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffa000;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="insights_box">
          <mxGeometry x="15" y="100" width="450" height="48" as="geometry" />
        </mxCell>
        <mxCell id="insight4" value="&lt;b&gt;4. Embedding 和 Output Layer 也很大&lt;/b&gt;&lt;br&gt;vocab_size × d_model = 30000 × 512 = 15.36M（出现两次！）&lt;br&gt;&lt;font color=&quot;#888888&quot; font-size=&quot;9&quot;&gt;词表越大，Embedding 越吃参数。LLaMA 用 BPE 压缩词表来减少这部分&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffa000;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="insights_box">
          <mxGeometry x="480" y="100" width="450" height="48" as="geometry" />
        </mxCell>

        <!-- Scaling law note -->
        <mxCell id="scaling_note" value="&lt;b&gt;📈 模型缩放规律&lt;/b&gt;&amp;#xa;&amp;#xa;d_model | 单层参数 | 6L Enc+6L Dec | 总计(含Emb)&amp;#xa;─────────────────────────────────────&amp;#xa;   128   |    ~66K   |     ~0.8M     |   ~2.0M&amp;#xa;   512   |   ~3.9M   |    ~56.8M     |  ~117M&amp;#xa;  1024   |   ~15.6M   |   ~226M       |  ~286M&amp;#xa;  4096   |  ~249M    |   ~3.6B       |  ~3.8B&amp;#xa; 12288   |  ~2.27B   |   ~32.7B      |  ~33B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontColor=#333333;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="full_container">
          <mxGeometry x="250" y="495" width="430" height="145" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

