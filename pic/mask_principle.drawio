          <mxGeometry x="539" y="306" width="52" height="34" as="geometry" />
        </mxCell>

        <!-- Causal mask code snippet -->
        <mxCell id="causal_code" value="&lt;b&gt;代码实现&lt;/b&gt;&amp;#xa;&amp;#xa;def make_causal_mask(seq_len):&amp;#xa;    # 创建下三角矩阵（下三角=0，上三角=-inf）&amp;#xa;    mask = torch.triu(torch.full(&amp;#xa;        (seq_len, seq_len), float('-inf')&amp;#xa;    ), diagonal=1)&amp;#xa;    return mask.bool()  # 返回 bool 类型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontColor=#333333;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="causal_container">
          <mxGeometry x="20" y="360" width="300" height="140" as="geometry" />
        </mxCell>

        <!-- Causal mask intuition -->
        <mxCell id="causal_intuition" value="&lt;b&gt;🧠 直觉理解&lt;/b&gt;&amp;#xa;&amp;#xa;生成“我”时：只能看到自己 → 关注度 100% 在自己身上&amp;#xa;生成“喜欢”时：能看到[“我”, “喜”] → 分配注意力给两者&amp;#xa;生成“你”时：能看到全部 → 综合考虑所有上下文&amp;#xa;&amp;#xa;⚠️ 上三角（红色）= 未来信息，被完全屏蔽！" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffa000;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="causal_container">
          <mxGeometry x="340" y="360" width="270" height="142" as="geometry" />
        </mxCell>

        <!-- Legend for causal -->
        <mxCell id="causal_legend" value="&lt;b&gt;图例&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontColor=#333333;fontSize=10;" vertex="1" parent="causal_container">
          <mxGeometry x="630" y="195" width="60" height="22" as="geometry" />
        </mxCell>
        <mxCell id="cl_green" value="可见（可关注）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=9;" vertex="1" parent="causal_container">
          <mxGeometry x="700" y="192" width="115" height="24" as="geometry" />
        </mxCell>
        <mxCell id="cl_red" value="屏蔽（-∞ → 0）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;fontSize=9;" vertex="1" parent="causal_container">
          <mxGeometry x="700" y="222" width="120" height="24" as="geometry" />
        </mxCell>

        <!-- ==================== PADDING MASK ==================== -->
        <mxCell id="pad_container" value="&lt;b&gt;🔇 Padding Mask（填充掩码）&lt;/b&gt;" style="swimlane;startSize=32;fillColor=#e8f5e9;strokeColor=#4caf50;fontColor=#2e7d32;horizontal=1;container=1;collapsible=0;rounded=1;arcSize=6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="900" y="60" width="850" height="520" as="geometry" />
        </mxCell>

        <mxCell id="pad_desc" value="&lt;b&gt;作用&lt;/b&gt;：屏蔽 &amp;lt;pad&amp;gt; token，防止模型关注无意义的填充位置&amp;#xa;&lt;b&gt;使用位置&lt;/b&gt;：Encoder Self-Attention + Decoder Cross-Attention（两处！）&amp;#xa;&lt;b&gt;原理&lt;/b&gt;：标记 pad 位置为 True，对应列/行填 -∞" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;fontColor=#333333;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="pad_container">
          <mxGeometry x="20" y="45" width="420" height="72" as="geometry" />
        </mxCell>

        <!-- Padding example -->
        <mxCell id="pad_example" value="&lt;b&gt;例句（补 pad 后）&lt;/b&gt;&amp;#xa;&quot;I love you &amp;lt;pad&amp;gt; &amp;lt;pad&amp;gt;&quot;&amp;#xa;seq_len = 5, 实际长度 = 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=11;" vertex="1" parent="pad_container">
          <mxGeometry x="470" y="42" width="210" height="62" as="geometry" />
