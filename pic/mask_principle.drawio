        </mxCell>

        <!-- ==================== CAUSAL MASK ==================== -->
        <mxCell id="causal_container" value="&lt;b&gt;🔒 Causal Mask（因果掩码 / 下三角掩码）&lt;/b&gt;" style="swimlane;startSize=32;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;arcSize=6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="850" height="520" as="geometry" />
        </mxCell>

        <!-- Causal mask description -->
        <mxCell id="causal_desc" value="&lt;b&gt;作用&lt;/b&gt;：防止 Decoder 在训练时&quot;偷看未来&quot;——生成第 t 个词时，只能看到前 t-1 个词&amp;#xa;&lt;b&gt;使用位置&lt;/b&gt;：Decoder 的 Masked Self-Attention（第一层子层）&amp;#xa;&lt;b&gt;原理&lt;/b&gt;：将注意力分数矩阵的上三角区域填充为 -∞，Softmax 后变为 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontColor=#333333;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="causal_container">
          <mxGeometry x="20" y="45" width="380" height="82" as="geometry" />
        </mxCell>

        <!-- Example sentence -->
        <mxCell id="causal_example" value="&lt;b&gt;例句&lt;/b&gt;: &quot;我 喜欢 你 &amp;lt;/end&amp;gt;&quot;&amp;#xa;(seq_len = 4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=11;" vertex="1" parent="causal_container">
          <mxGeometry x="430" y="45" width="200" height="46" as="geometry" />
