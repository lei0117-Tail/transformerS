        </mxCell>

        <!-- Padding mask code and notes -->
        <mxCell id="pad_code" value="&lt;b&gt;代码实现&lt;/b&gt;&amp;#xa;&amp;#xa;def make_padding_mask(seq, pad_idx):&amp;#xa;    # seq != pad_idx 的位置为 False（保留）&amp;#xa;    # seq == pad_idx 的位置为 True（屏蔽）&amp;#xa;    return (seq != pad_idx).bool().unsqueeze(1)&amp;#xa;&amp;#xa;# 输出 shape: [batch, 1, 1, seq_len]&amp;#xa;# 用 &amp; 运算与 causal_mask 合并" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontColor=#333333;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="pad_container">
          <mxGeometry x="280" y="275" width="280" height="150" as="geometry" />
        </mxCell>

        <mxCell id="pad_note" value="&lt;b&gt;💡 关键点&lt;/b&gt;&amp;#xa;&amp;#xa;• Padding Mask 同时用在两个地方：&amp;#xa;  1️⃣ Encoder 内部的 Self-Attention&amp;#xa;  2️⃣ Decoder Cross-Attention（K/V 来自 Encoder）&amp;#xa;&amp;#xa;• Causal Mask 只用在一个地方：&amp;#xa;  Decoder 的 Masked Self-Attention&amp;#xa;&amp;#xa;• 两种 Mask 可以用 &amp; 合并（PyTorch 要求统一 bool 类型）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="pad_container">
          <mxGeometry x="580" y="275" width="250" height="190" as="geometry" />
        </mxCell>

        <!-- Two masks combined visualization -->
        <mxCell id="combined_box" value="&lt;b&gt;🔄 两种 Mask 的组合使用&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#fafafa;strokeColor=#999999;fontColor=#333333;horizontal=1;container=1;collapsible=0;rounded=1;fontSize=11;" vertex="1" parent="pad_container">
